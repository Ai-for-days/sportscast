GCP_PROJECT_ID=sportscast-weather
GCP_CREDENTIALS_BASE64=
BIGQUERY_DATASET=

# Step 133 — explicit forecast provider selection. Recognized values:
#
#   open-meteo                    Default. Blends ECMWF IFS + GFS + HRRR +
#                                 ICON, refreshed hourly. Real UV, precip-
#                                 probability, visibility, gusts.
#   weathernext-bigquery-sample   Research / A-B only. Google's
#                                 `bigquery-public-data.weathernext.sample`.
#                                 Downsampled, ~daily updates, fabricates
#                                 UV / precip-probability / visibility on
#                                 the way through. NOT for production traffic.
#   weathernext-production        STUB today. Strategic preferred source
#                                 once production WeatherNext access (Vertex
#                                 AI / BigQuery production tables / Earth
#                                 Engine) is wired up. Currently logs a
#                                 warning and falls back to open-meteo.
#                                 See docs/weathernext-integration-plan.md.
#
# Unset → open-meteo. Unknown values → open-meteo with warning.
FORECAST_PROVIDER=

# Legacy flag (Step 132 follow-up). Still recognized for backward
# compatibility — if FORECAST_PROVIDER is unset and this is "true",
# weather-queries.ts maps it to weathernext-bigquery-sample.
# Prefer FORECAST_PROVIDER going forward.
USE_BIGQUERY_FORECAST=

# Step 135 — Vertex AI WeatherNext production client config (placeholders).
# All four below must be set before FORECAST_PROVIDER=weathernext-production
# will even attempt the inference call. When unset, the client returns
# failureMode=unconfigured and weather-queries.ts falls back to Open-Meteo.
#
# NOTE: The exact endpoint contract has not yet been confirmed against
# current Google docs (Step 135 is a foundation spike). The client
# structurally returns failureMode=endpoint_unconfirmed today even when
# all four are populated. See docs/weathernext-integration-plan.md §10
# for the unknowns that must be resolved before the inference body is
# wired up.
WEATHERNEXT_VERTEX_REGION=
WEATHERNEXT_VERTEX_ENDPOINT_ID=
WEATHERNEXT_VERTEX_MODEL_ID=

# Step 142 — WeatherNext BigQuery PRODUCTION fallback path config
# (placeholders). Distinct from the public sample at
# `bigquery-public-data.weathernext.sample`. Reuses the existing
# GCP_CREDENTIALS_BASE64 auth.
#
# NOTE: even when all three are populated, the production query path is
# still disabled because the dataset/table/schema are UNCONFIRMED in
# this build. tryWeatherNextBigQueryForecast returns
# failureMode=contract_unconfirmed; weather-queries.ts falls back to
# Open-Meteo. See docs/weathernext-contract-readiness.md for what must
# be verified before the contract gate can be flipped.
#
# WEATHERNEXT_BIGQUERY_PROJECT is optional — falls back to GCP_PROJECT_ID
# when the production tables live in the same GCP project.
WEATHERNEXT_BIGQUERY_PROJECT=
WEATHERNEXT_BIGQUERY_DATASET=
WEATHERNEXT_BIGQUERY_TABLE=

# Step 139 — secret protecting the forecast quality cron endpoint
# (/api/cron/forecast-quality). The endpoint accepts the secret as
# `Authorization: Bearer <secret>` only — no query string, no body.
# Vercel Cron sends this header automatically when CRON_SECRET (or this
# var, if you prefer feature isolation) is set on the project.
#
# Resolution order: FORECAST_QUALITY_CRON_SECRET, then the project-wide
# CRON_SECRET (already used by /api/cron/grade-wagers and
# /api/cron/verify-forecasts). If neither is set, every request is
# rejected. The secret is never returned in any response or log line.
#
# See docs/forecast-quality-cron-setup.md for the deployment recipe.
FORECAST_QUALITY_CRON_SECRET=

# Step 117B / 118 — Kalshi integration (placeholders only; never commit real values)
# Server-side use only. The private key must never be exposed to client code.
# Prefer KALSHI_PRIVATE_KEY_BASE64 — the raw PEM is multi-line, which most
# .env loaders mangle. Base64-encode the entire PEM (including the BEGIN/END
# headers) and paste the single line below. Decoded server-side only.
# KALSHI_PRIVATE_KEY (raw PEM) is still read by older code paths if set.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_BASE64=
KALSHI_ENV=demo
KALSHI_READ_ONLY=true
