GCP_PROJECT_ID=sportscast-weather
GCP_CREDENTIALS_BASE64=
BIGQUERY_DATASET=

# Step 133 — explicit forecast provider selection. Recognized values:
#
#   open-meteo                    Default. Blends ECMWF IFS + GFS + HRRR +
#                                 ICON, refreshed hourly. Real UV, precip-
#                                 probability, visibility, gusts.
#   weathernext-bigquery-sample   Research / A-B only. Google's
#                                 `bigquery-public-data.weathernext.sample`.
#                                 Downsampled, ~daily updates, fabricates
#                                 UV / precip-probability / visibility on
#                                 the way through. NOT for production traffic.
#   weathernext-production        STUB today. Strategic preferred source
#                                 once production WeatherNext access (Vertex
#                                 AI / BigQuery production tables / Earth
#                                 Engine) is wired up. Currently logs a
#                                 warning and falls back to open-meteo.
#                                 See docs/weathernext-integration-plan.md.
#
# Unset → open-meteo. Unknown values → open-meteo with warning.
FORECAST_PROVIDER=

# Legacy flag (Step 132 follow-up). Still recognized for backward
# compatibility — if FORECAST_PROVIDER is unset and this is "true",
# weather-queries.ts maps it to weathernext-bigquery-sample.
# Prefer FORECAST_PROVIDER going forward.
USE_BIGQUERY_FORECAST=

# Step 117B / 118 — Kalshi integration (placeholders only; never commit real values)
# Server-side use only. The private key must never be exposed to client code.
# Prefer KALSHI_PRIVATE_KEY_BASE64 — the raw PEM is multi-line, which most
# .env loaders mangle. Base64-encode the entire PEM (including the BEGIN/END
# headers) and paste the single line below. Decoded server-side only.
# KALSHI_PRIVATE_KEY (raw PEM) is still read by older code paths if set.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_BASE64=
KALSHI_ENV=demo
KALSHI_READ_ONLY=true
