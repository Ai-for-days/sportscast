{
  "crons": [
    {
      "path": "/api/cron/grade-wagers",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/verify-forecasts",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/forecast-quality?action=seeded-comparison",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/forecast-quality?action=quality-report",
      "schedule": "30 7 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.wageronweather.com" }],
      "destination": "https://wageronweather.com/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/admin/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/api/admin/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/icons/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/logo-header.(webp|png)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000" }
      ]
    },
    {
      "source": "/logo-hero.(webp|png)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000" }
      ]
    },
    {
      "source": "/og-image.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000" }
      ]
    },
    {
      "source": "/favicon.(svg|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000" }
      ]
    }
  ]
}
