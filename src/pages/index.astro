---
import BaseLayout from '../components/layout/BaseLayout.astro';
import HomepageSearch from '../components/search/HomepageSearch';
import HomeHero from '../components/public/HomeHero';
import FeaturedMarkets from '../components/public/FeaturedMarkets';
import HowItWorks from '../components/public/HowItWorks';
import TrustSafetyStrip from '../components/public/TrustSafetyStrip';
import { getHomepageMeta } from '../lib/seo-meta';
import { getOrganizationSchema, getWebSiteSchema } from '../lib/schema-markup';
import { CITY_HUB_ROSTER } from '../lib/seo/zip-priority';
import { listPriorityZips } from '../lib/priority-zip-content';
import { stateAbbrToSlug, STATE_ABBR_TO_FULL } from '../lib/state-names';

// Step 176 — homepage is the apex of the hub graph. Surface a tight
// tier-aware list: a handful of priority state hubs, every curated
// city hub, and the manually-designated Tier-1 ZIPs. The page never
// links to a flat list of long-tail ZIPs (per spec).
export const prerender = true;

const meta = getHomepageMeta();
const jsonLd = [getOrganizationSchema(), getWebSiteSchema()];

const HOMEPAGE_STATE_HUBS: ReadonlyArray<string> = ['NY', 'TX', 'CA', 'FL', 'MN', 'OK'];
const homepageStateLinks = HOMEPAGE_STATE_HUBS.map((abbr) => ({
  abbr,
  label: titleCase(STATE_ABBR_TO_FULL[abbr] ?? abbr),
  url: `/weather/${stateAbbrToSlug(abbr)}`,
}));

const homepageCityHubLinks = CITY_HUB_ROSTER.map((hub) => ({
  label: `${hub.city}, ${hub.state}`,
  url: `/weather/${stateAbbrToSlug(hub.state)}/${citySlug(hub.city)}`,
}));

const homepageTier1Zips = listPriorityZips().map((p) => ({
  label: `${p.city} ${p.zip}`,
  url: `/united-states-${stateAbbrToSlug(p.stateAbbr)}-${citySlug(p.city)}-${p.zip}`,
}));

function citySlug(city: string): string {
  return city
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/(^-|-$)/g, '');
}

function titleCase(slug: string): string {
  return slug
    .split('-')
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ');
}
---

<BaseLayout title={meta.title} description={meta.description} noTitleSuffix={meta.noTitleSuffix} jsonLd={jsonLd}>
  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-field-dark via-field to-sky px-4 py-20 pb-40 text-white">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_40%,rgba(255,255,255,0.1),transparent)]"></div>
    <div class="relative mx-auto max-w-4xl text-center">
      <picture>
        <source srcset="/logo-hero.webp" type="image/webp" />
        <img src="/logo-hero.png" alt="Wager on Weather" class="mx-auto mb-6 h-28 w-auto drop-shadow-lg sm:h-36" width="288" height="144" />
      </picture>
      <!-- Search bar with live autocomplete -->
      <div class="mx-auto mb-8 max-w-2xl">
        <HomepageSearch client:only="react" />
      </div>
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl">
        Weather Intelligence<br />for Sports Bettors
      </h1>
      <div class="mt-4 flex flex-wrap items-center justify-center gap-3">
        <a href="/wagers" class="inline-block rounded-lg bg-white px-6 py-3 text-sm font-semibold text-slate-900 transition-colors hover:bg-slate-100">
          Browse weather markets
        </a>
        <a href="/venues" class="inline-block rounded-lg border-2 border-white/30 px-6 py-3 text-sm font-semibold text-white backdrop-blur-sm transition-colors hover:bg-white/10">
          Sports Venue Forecasts
        </a>
      </div>
    </div>
  </section>

  <HomeHero />
  <FeaturedMarkets client:load />
  <HowItWorks />
  <TrustSafetyStrip />

  <!-- Step 173/176 — best-pages-first hub link architecture. Surfaces
       priority state hubs + every curated city hub + Tier-1 ZIPs.
       Never links to a flat long-tail ZIP list. Public links only —
       never admin URLs. -->
  <section class="bg-slate-50 px-4 py-10 dark:bg-surface-dark">
    <div class="mx-auto max-w-4xl">
      <h2 class="mb-4 text-xl font-bold text-slate-900 dark:text-text-dark">
        Popular Weather Hubs &amp; ZIP Codes
      </h2>
      <p class="mb-6 text-sm text-slate-600 dark:text-text-dark-muted">
        Browse forecasts by US state and city, or jump straight to a featured ZIP code.
      </p>

      <div class="grid gap-6 sm:grid-cols-3">
        <div>
          <h3 class="mb-2 text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-text-dark-muted">Priority state hubs</h3>
          <ul class="space-y-1 text-sm">
            {homepageStateLinks.map((s) => (
              <li><a href={s.url} class="text-field hover:underline">{s.label} Weather</a></li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="mb-2 text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-text-dark-muted">City hubs</h3>
          <ul class="space-y-1 text-sm">
            {homepageCityHubLinks.map((c) => (
              <li><a href={c.url} class="text-field hover:underline">{c.label}</a></li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="mb-2 text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-text-dark-muted">Tier 1 ZIP forecasts</h3>
          <ul class="space-y-1 text-sm">
            {homepageTier1Zips.map((z) => (
              <li><a href={z.url} class="text-field hover:underline">{z.label}</a></li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
