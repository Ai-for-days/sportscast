---
import BaseLayout from '../components/layout/BaseLayout.astro';
import HomepageSearch from '../components/search/HomepageSearch';
import HomeHero from '../components/public/HomeHero';
import FeaturedMarkets from '../components/public/FeaturedMarkets';
import HowItWorks from '../components/public/HowItWorks';
import TrustSafetyStrip from '../components/public/TrustSafetyStrip';
import { getHomepageMeta } from '../lib/seo-meta';
import { getOrganizationSchema, getWebSiteSchema } from '../lib/schema-markup';

export const prerender = true;

const meta = getHomepageMeta();
const jsonLd = [getOrganizationSchema(), getWebSiteSchema()];
---

<BaseLayout title={meta.title} description={meta.description} noTitleSuffix={meta.noTitleSuffix} jsonLd={jsonLd}>
  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-field-dark via-field to-sky px-4 py-20 pb-40 text-white">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_40%,rgba(255,255,255,0.1),transparent)]"></div>
    <div class="relative mx-auto max-w-4xl text-center">
      <picture>
        <source srcset="/logo-hero.webp" type="image/webp" />
        <img src="/logo-hero.png" alt="Wager on Weather" class="mx-auto mb-6 h-28 w-auto drop-shadow-lg sm:h-36" width="288" height="144" />
      </picture>
      <!-- Search bar with live autocomplete -->
      <div class="mx-auto mb-8 max-w-2xl">
        <HomepageSearch client:only="react" />
      </div>
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl">
        Weather Intelligence<br />for Sports Bettors
      </h1>
      <div class="mt-4 flex flex-wrap items-center justify-center gap-3">
        <a href="/wagers" class="inline-block rounded-lg bg-white px-6 py-3 text-sm font-semibold text-slate-900 transition-colors hover:bg-slate-100">
          Browse weather markets
        </a>
        <a href="/venues" class="inline-block rounded-lg border-2 border-white/30 px-6 py-3 text-sm font-semibold text-white backdrop-blur-sm transition-colors hover:bg-white/10">
          Sports Venue Forecasts
        </a>
      </div>
    </div>
  </section>

  <HomeHero />
  <FeaturedMarkets client:load />
  <HowItWorks />
  <TrustSafetyStrip />

  <!-- Step 173 — internal hub link architecture. Surfaces state + city
       hubs and the priority ZIP pages to feed Google's discovery
       crawl. Public links only — never admin URLs. -->
  <section class="bg-slate-50 px-4 py-10 dark:bg-surface-dark">
    <div class="mx-auto max-w-4xl">
      <h2 class="mb-4 text-xl font-bold text-slate-900 dark:text-text-dark">
        Popular Weather Hubs &amp; ZIP Codes
      </h2>
      <p class="mb-6 text-sm text-slate-600 dark:text-text-dark-muted">
        Browse forecasts by US state and city, or jump straight to a high-traffic ZIP code.
      </p>

      <div class="grid gap-6 sm:grid-cols-3">
        <div>
          <h3 class="mb-2 text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-text-dark-muted">State hubs</h3>
          <ul class="space-y-1 text-sm">
            <li><a href="/weather/new-york" class="text-field hover:underline">New York Weather</a></li>
            <li><a href="/weather/minnesota" class="text-field hover:underline">Minnesota Weather</a></li>
            <li><a href="/weather/texas" class="text-field hover:underline">Texas Weather</a></li>
            <li><a href="/weather/oklahoma" class="text-field hover:underline">Oklahoma Weather</a></li>
          </ul>
        </div>
        <div>
          <h3 class="mb-2 text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-text-dark-muted">City hubs</h3>
          <ul class="space-y-1 text-sm">
            <li><a href="/weather/new-york/new-york" class="text-field hover:underline">New York, NY</a></li>
            <li><a href="/weather/minnesota/saint-paul" class="text-field hover:underline">Saint Paul, MN</a></li>
            <li><a href="/weather/texas/houston" class="text-field hover:underline">Houston, TX</a></li>
            <li><a href="/weather/texas/dallas" class="text-field hover:underline">Dallas, TX</a></li>
            <li><a href="/weather/oklahoma/oklahoma-city" class="text-field hover:underline">Oklahoma City, OK</a></li>
          </ul>
        </div>
        <div>
          <h3 class="mb-2 text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-text-dark-muted">Featured ZIPs</h3>
          <ul class="space-y-1 text-sm">
            <li><a href="/united-states-new-york-new-york-10001" class="text-field hover:underline">New York 10001</a></li>
            <li><a href="/united-states-minnesota-saint-paul-55101" class="text-field hover:underline">Saint Paul 55101</a></li>
            <li><a href="/united-states-texas-houston-77205" class="text-field hover:underline">Houston 77205</a></li>
            <li><a href="/united-states-texas-dallas-75201" class="text-field hover:underline">Dallas 75201</a></li>
            <li><a href="/united-states-oklahoma-oklahoma-city-73101" class="text-field hover:underline">Oklahoma City 73101</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
