---
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import SystemNav from '../../../components/admin/SystemNav';
import { requireAdmin } from '../../../lib/admin-auth';
import {
  getOrInitPortfolioState,
  savePortfolioState,
  recomputeDerivedFields,
  type AlertPayload,
} from '../../../lib/crypto-paper-portfolio';
import { simulateSignal, SAMPLE_SIGNAL } from '../../../lib/crypto-paper-trade-simulator';
import { renderCryptoTradeAlertPayload } from '../../../lib/crypto-trade-alert-renderer';

export const prerender = false;

const session = await requireAdmin(Astro.request);
if (!session) {
  return Astro.redirect('/admin');
}

// Page modes:
//   • Default: render `state.lastAlert` if present, else preview the
//     built-in SAMPLE_SIGNAL without persisting.
//   • ?simulateSample=1: run the simulator against SAMPLE_SIGNAL and
//     persist the resulting alert so the page can echo it.
const url = new URL(Astro.request.url);
const simulateSample = url.searchParams.get('simulateSample') === '1';

let alert: AlertPayload | null = null;
let loadError: string | null = null;
let didPersist = false;

try {
  const state = await getOrInitPortfolioState();
  if (simulateSample) {
    const result = simulateSignal(state, SAMPLE_SIGNAL);
    await savePortfolioState({ ...result.updatedState, lastAlert: result.alert });
    alert = result.alert;
    didPersist = true;
  } else if (state.lastAlert) {
    alert = state.lastAlert;
  } else {
    // No persisted alert yet — render the sample alert in dry-run mode.
    const result = simulateSignal(recomputeDerivedFields(state), SAMPLE_SIGNAL);
    alert = result.alert;
  }
} catch (err: any) {
  loadError = err?.message ?? String(err);
}

const rendered = alert
  ? renderCryptoTradeAlertPayload(alert, { recipient: 'derek@derekbdavis.com' })
  : null;
---

<BaseLayout title="Crypto Paper Alert Preview — Admin" noTitleSuffix noIndex>
  <div class="min-h-screen bg-slate-50" style="color-scheme: light;">
    <div class="mx-auto max-w-7xl px-4 py-6 space-y-6">
      <div class="rounded-lg border border-amber-300 bg-amber-50 px-4 py-3 text-sm text-amber-900">
        <strong>Paper trading only. Research only. Not financial advice.</strong>
        Preview-only — no mailer is wired up. No external send.
      </div>

      <div class="rounded-lg border border-slate-200 bg-white p-4">
        <div class="flex items-baseline justify-between gap-4 flex-wrap">
          <div>
            <h1 class="text-xl font-bold text-slate-900">Crypto Paper Alert Preview</h1>
            <p class="text-xs text-slate-600 mt-1">
              Server-rendered HTML + plaintext preview of the most recent paper-trade alert
              (or the built-in <code>SAMPLE_SIGNAL</code> when no alert has been simulated yet).
              Recipient stamp: <code>derek@derekbdavis.com</code>.
            </p>
            <p class="text-xs text-amber-700 mt-1">
              No SMTP / SES / SendGrid / Resend / Mailgun / Postmark client is configured. No outbound send.
            </p>
            {didPersist && (
              <p class="text-xs text-emerald-700 mt-1">
                Sample simulation persisted. Open the portfolio page to see the resulting trade.
              </p>
            )}
          </div>
          <div class="flex gap-2 flex-wrap">
            <a href="/admin/system/crypto-paper-alert-preview" class="rounded border border-slate-300 bg-white px-3 py-1.5 text-sm font-semibold text-slate-700 hover:bg-slate-50">Refresh</a>
            <a href="/admin/system/crypto-paper-alert-preview?simulateSample=1" class="rounded bg-blue-600 px-3 py-1.5 text-sm font-semibold text-white hover:bg-blue-700">
              Simulate sample signal (persist)
            </a>
            <a href="/admin/system/crypto-paper-portfolio" class="rounded border border-slate-300 bg-white px-3 py-1.5 text-sm font-semibold text-slate-700 hover:bg-slate-50">Open portfolio</a>
          </div>
        </div>
      </div>

      {loadError && (
        <div class="rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-800">
          Failed to load alert preview: <code>{loadError}</code>. No customer impact.
        </div>
      )}

      {rendered && (
        <>
          <div class="rounded-lg border border-slate-200 bg-white p-4">
            <h2 class="text-sm font-semibold text-slate-900 mb-2">Subject</h2>
            <code class="block bg-slate-100 rounded p-2 text-xs text-slate-800">{rendered.subject}</code>
          </div>

          <div class="grid gap-6 lg:grid-cols-2">
            <div class="rounded-lg border border-slate-200 bg-white p-4">
              <h2 class="text-sm font-semibold text-slate-900 mb-2">HTML preview</h2>
              <div class="rounded border border-slate-200 p-4 bg-white" set:html={rendered.html} />
            </div>

            <div class="rounded-lg border border-slate-200 bg-white p-4">
              <h2 class="text-sm font-semibold text-slate-900 mb-2">Plain text</h2>
              <pre class="overflow-auto rounded bg-slate-50 p-3 text-xs text-slate-800 whitespace-pre-wrap">{rendered.text}</pre>
            </div>
          </div>

          <div class="rounded-lg border border-amber-300 bg-amber-50 p-4 text-xs text-amber-900">
            <strong>Send-test-email controls intentionally absent.</strong>
            No SMTP / SES / SendGrid / Resend / Mailgun / Postmark client is configured. The renderer
            output (<code>renderCryptoTradeAlertPayload(alert)</code>) is shaped so a future step
            can wire whatever transport gets adopted without changing this preview.
          </div>
        </>
      )}

      <SystemNav client:load activeHref="/admin/system/crypto-paper-alert-preview" />
    </div>
  </div>
</BaseLayout>
