---
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import DailyOperatorRunbook from '../../../components/admin/DailyOperatorRunbook';
import { requireAdmin } from '../../../lib/admin-auth';
export const prerender = false;
const session = await requireAdmin(Astro.request);
if (!session) { return Astro.redirect('/admin'); }
---
<BaseLayout title="Daily Runbook — Admin" noTitleSuffix noIndex>
  <div class="min-h-screen bg-white" style="color-scheme: light;">
    <div class="mx-auto max-w-7xl px-4 py-6">
      <DailyOperatorRunbook client:only="react" />
    </div>
  </div>
</BaseLayout>
