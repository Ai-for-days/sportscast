---
// ── Step 176: Admin-only SEO health dashboard ──────────────────────────
//
// Read-only snapshot of the site's SEO architecture (sitemap shard
// counts, hub counts, tier counts, noindex route groups, canonical
// host). **No GSC API integration** — see `gsc-types.ts` for the
// future structures. **No secrets.** Admin-gated; noindex,nofollow.
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import SystemNav from '../../../components/admin/SystemNav';
import { requireAdmin } from '../../../lib/admin-auth';
import { buildSeoHealthSnapshot } from '../../../lib/seo/seo-health';

export const prerender = false;

const session = await requireAdmin(Astro.request);
if (!session) {
  return Astro.redirect('/admin');
}

const snapshot = buildSeoHealthSnapshot();
const tierTotal = snapshot.tierCounts.tier1 + snapshot.tierCounts.tier2 + snapshot.tierCounts.tier3;
const tier1Pct = tierTotal > 0 ? Math.round((snapshot.tierCounts.tier1 / tierTotal) * 1000) / 10 : 0;
const tier2Pct = tierTotal > 0 ? Math.round((snapshot.tierCounts.tier2 / tierTotal) * 1000) / 10 : 0;
const tier3Pct = tierTotal > 0 ? Math.round((snapshot.tierCounts.tier3 / tierTotal) * 1000) / 10 : 0;
---

<BaseLayout title="SEO Health — Admin" noTitleSuffix noIndex>
  <div class="min-h-screen bg-slate-50" style="color-scheme: light;">
    <div class="mx-auto max-w-7xl px-4 py-6 space-y-6">
      <header>
        <h1 class="text-2xl font-bold text-slate-900">SEO Health</h1>
        <p class="mt-1 text-sm text-slate-600">
          Read-only snapshot of the site's SEO architecture. No Search Console
          API integration yet. Generated at {new Date(snapshot.generatedAt).toUTCString()}.
        </p>
      </header>

      <section class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="mb-3 text-lg font-semibold text-slate-900">Canonical host</h2>
        <dl class="grid grid-cols-1 gap-3 sm:grid-cols-2 text-sm">
          <div>
            <dt class="font-medium text-slate-500">Canonical host</dt>
            <dd class="font-mono text-slate-900">{snapshot.canonicalHost}</dd>
          </div>
          <div>
            <dt class="font-medium text-slate-500">Sitemap index</dt>
            <dd>
              <a href={snapshot.sitemapIndexUrl} class="font-mono text-blue-600 underline">
                {snapshot.sitemapIndexUrl}
              </a>
            </dd>
          </div>
        </dl>
      </section>

      <section class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="mb-3 text-lg font-semibold text-slate-900">Hub coverage</h2>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-3 text-sm">
          <div class="rounded-lg bg-slate-50 p-3">
            <div class="text-xs uppercase tracking-wider text-slate-500">State hubs</div>
            <div class="mt-1 text-2xl font-bold text-slate-900">{snapshot.hubCounts.stateHubs}</div>
          </div>
          <div class="rounded-lg bg-slate-50 p-3">
            <div class="text-xs uppercase tracking-wider text-slate-500">City hubs</div>
            <div class="mt-1 text-2xl font-bold text-slate-900">{snapshot.hubCounts.cityHubs}</div>
          </div>
          <div class="rounded-lg bg-slate-50 p-3">
            <div class="text-xs uppercase tracking-wider text-slate-500">ZIP pages</div>
            <div class="mt-1 text-2xl font-bold text-slate-900">{snapshot.hubCounts.zipPages.toLocaleString()}</div>
          </div>
        </div>
      </section>

      <section class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="mb-3 text-lg font-semibold text-slate-900">ZIP priority tiers</h2>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-3 text-sm">
          <div class="rounded-lg bg-emerald-50 p-3">
            <div class="text-xs uppercase tracking-wider text-emerald-700">Tier 1</div>
            <div class="mt-1 text-2xl font-bold text-emerald-900">{snapshot.tierCounts.tier1.toLocaleString()}</div>
            <div class="text-xs text-emerald-700">{tier1Pct}% of dataset</div>
          </div>
          <div class="rounded-lg bg-sky-50 p-3">
            <div class="text-xs uppercase tracking-wider text-sky-700">Tier 2</div>
            <div class="mt-1 text-2xl font-bold text-sky-900">{snapshot.tierCounts.tier2.toLocaleString()}</div>
            <div class="text-xs text-sky-700">{tier2Pct}% of dataset</div>
          </div>
          <div class="rounded-lg bg-slate-100 p-3">
            <div class="text-xs uppercase tracking-wider text-slate-700">Tier 3 (long-tail)</div>
            <div class="mt-1 text-2xl font-bold text-slate-900">{snapshot.tierCounts.tier3.toLocaleString()}</div>
            <div class="text-xs text-slate-700">{tier3Pct}% of dataset</div>
          </div>
        </div>
        <p class="mt-3 text-xs text-slate-500">
          Tier 1 = priority ZIPs + ZIPs in tier-1 metros or curated city hubs.
          Tier 2 = ZIPs in tier-2/3 curated cities. Tier 3 = everything else.
        </p>
      </section>

      <section class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <div class="mb-3 flex items-baseline justify-between">
          <h2 class="text-lg font-semibold text-slate-900">Sitemap shards</h2>
          <p class="text-sm text-slate-600">
            {snapshot.shardCount} shards · {snapshot.totalSitemapUrls.toLocaleString()} total URLs
          </p>
        </div>
        <div class="overflow-x-auto">
          <table class="min-w-full text-sm">
            <thead>
              <tr class="border-b border-slate-200 text-left">
                <th class="py-2 pr-4 font-semibold text-slate-700">Shard</th>
                <th class="py-2 pr-4 font-semibold text-slate-700">URLs</th>
                <th class="py-2 font-semibold text-slate-700">URL</th>
              </tr>
            </thead>
            <tbody>
              {snapshot.shards.map((s) => (
                <tr class="border-b border-slate-100">
                  <td class="py-2 pr-4 font-mono text-slate-900">{s.label}</td>
                  <td class="py-2 pr-4 text-slate-700">{s.urlCount.toLocaleString()}</td>
                  <td class="py-2 font-mono text-xs">
                    <a href={s.url} class="text-blue-600 hover:underline">{s.url.replace(snapshot.canonicalHost, '')}</a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="mb-3 text-lg font-semibold text-slate-900">Noindex route groups</h2>
        <p class="mb-3 text-xs text-slate-500">
          Routes emit <code class="bg-slate-100 px-1">meta robots noindex,nofollow</code> via BaseLayout.
          Admin and admin-API also emit matching <code class="bg-slate-100 px-1">X-Robots-Tag</code>
          headers via <code class="bg-slate-100 px-1">vercel.json</code>.
        </p>
        <ul class="grid grid-cols-1 gap-2 sm:grid-cols-2 text-sm">
          {snapshot.noIndexGroups.map((g) => (
            <li class="rounded-md border border-slate-200 px-3 py-2">
              <span class="font-mono text-slate-900">{g.prefix}</span>
              <span class="ml-2 text-xs uppercase tracking-wider text-slate-500">{g.reason}</span>
            </li>
          ))}
        </ul>
      </section>

      <p class="text-xs text-slate-500">
        Admin operator dashboard. Read-only. No Search Console API call. No secrets.
      </p>

      <SystemNav client:load activeHref="/admin/system/seo-health" />
    </div>
  </div>
</BaseLayout>
