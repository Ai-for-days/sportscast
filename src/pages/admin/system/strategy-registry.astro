---
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import StrategyRegistry from '../../../components/admin/StrategyRegistry';
import { requireAdmin } from '../../../lib/admin-auth';
export const prerender = false;
const session = await requireAdmin(Astro.request);
if (!session) { return Astro.redirect('/admin'); }
---
<BaseLayout title="Strategy Registry — Admin" noTitleSuffix noIndex>
  <div class="min-h-screen bg-white" style="color-scheme: light;">
    <div class="mx-auto max-w-7xl px-4 py-6">
      <StrategyRegistry client:only="react" />
    </div>
  </div>
</BaseLayout>
