---
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import SystemNav from '../../../components/admin/SystemNav';
import { requireAdmin } from '../../../lib/admin-auth';
import {
  getOrInitPortfolioState,
  recomputeDerivedFields,
  type PaperPortfolioState,
} from '../../../lib/crypto-paper-portfolio';
import { MIN_BUY_SCORE } from '../../../lib/crypto-paper-trade-simulator';

export const prerender = false;

const session = await requireAdmin(Astro.request);
if (!session) {
  return Astro.redirect('/admin');
}

let state: PaperPortfolioState | null = null;
let loadError: string | null = null;
try {
  const raw = await getOrInitPortfolioState();
  state = recomputeDerivedFields(raw);
} catch (err: any) {
  loadError = err?.message ?? String(err);
}

const fmtUsd = (n: number) =>
  Number.isFinite(n)
    ? n.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 2 })
    : '—';
const fmtPct = (n: number) => (Number.isFinite(n) ? `${n.toFixed(2)}%` : '—');
const fmtQty = (n: number) =>
  Number.isFinite(n) ? n.toLocaleString('en-US', { maximumFractionDigits: 6 }) : '—';
const fmtTime = (s: string | undefined) => {
  if (!s) return '—';
  const d = new Date(s);
  return Number.isNaN(d.getTime()) ? s : d.toLocaleString();
};

const recentTrades = state ? state.trades.slice(-50).reverse() : [];
---

<BaseLayout title="Crypto Paper Portfolio — Admin" noTitleSuffix noIndex>
  <div class="min-h-screen bg-slate-50" style="color-scheme: light;">
    <div class="mx-auto max-w-7xl px-4 py-6 space-y-6">
      <div class="rounded-lg border border-amber-300 bg-amber-50 px-4 py-3 text-sm text-amber-900">
        <strong>Paper trading only. Research only. Not financial advice.</strong>
        No real funds, exchanges, broker APIs, custody, wallets, or order execution are involved.
      </div>

      <div class="rounded-lg border border-slate-200 bg-white p-4">
        <div class="flex items-baseline justify-between gap-4 flex-wrap">
          <div>
            <h1 class="text-xl font-bold text-slate-900">Crypto Paper Portfolio</h1>
            <p class="text-xs text-slate-600 mt-1">
              Side-effect-free $100,000 model bankroll. Buys are simulated from incoming crypto signals; all P&amp;L is hypothetical.
            </p>
            <p class="text-xs text-slate-500 mt-1">
              Qualifying buy: <code>recommendation === 'buy'</code> AND <code>score &ge; {MIN_BUY_SCORE}</code>.
              Sell / trim require an existing open position.
            </p>
          </div>
          <div class="flex gap-2">
            <a href="/admin/system/crypto-paper-portfolio" class="rounded border border-slate-300 bg-white px-3 py-1.5 text-sm font-semibold text-slate-700 hover:bg-slate-50">Refresh</a>
            <a href="/admin/system/crypto-paper-alert-preview" class="rounded bg-blue-600 px-3 py-1.5 text-sm font-semibold text-white hover:bg-blue-700">Open alert preview</a>
          </div>
        </div>
      </div>

      {loadError && (
        <div class="rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-800">
          Failed to load portfolio: <code>{loadError}</code>. No customer impact.
        </div>
      )}

      {state && (
        <>
          <div class="grid gap-3 md:grid-cols-3 lg:grid-cols-6">
            <div class="rounded-lg border border-slate-200 bg-white p-3">
              <div class="text-[10px] uppercase tracking-wider text-slate-500">Starting bankroll</div>
              <div class="text-base font-semibold text-slate-900 mt-1">{fmtUsd(state.startingBankroll)}</div>
            </div>
            <div class="rounded-lg border border-slate-200 bg-white p-3">
              <div class="text-[10px] uppercase tracking-wider text-slate-500">Current equity</div>
              <div class="text-base font-semibold text-slate-900 mt-1">{fmtUsd(state.totalEquity)}</div>
            </div>
            <div class="rounded-lg border border-slate-200 bg-white p-3">
              <div class="text-[10px] uppercase tracking-wider text-slate-500">Cash</div>
              <div class="text-base font-semibold text-slate-900 mt-1">{fmtUsd(state.cashBalance)}</div>
            </div>
            <div class="rounded-lg border border-slate-200 bg-white p-3">
              <div class="text-[10px] uppercase tracking-wider text-slate-500">Exposure</div>
              <div class="text-base font-semibold text-slate-900 mt-1">{fmtPct(state.exposurePct)}</div>
            </div>
            <div class={`rounded-lg border bg-white p-3 ${state.realizedPnl >= 0 ? 'border-emerald-200' : 'border-red-200'}`}>
              <div class="text-[10px] uppercase tracking-wider text-slate-500">Realized P&amp;L</div>
              <div class={`text-base font-semibold mt-1 ${state.realizedPnl >= 0 ? 'text-emerald-700' : 'text-red-700'}`}>
                {fmtUsd(state.realizedPnl)}
              </div>
            </div>
            <div class={`rounded-lg border bg-white p-3 ${state.cumulativeReturnPct >= 0 ? 'border-emerald-200' : 'border-red-200'}`}>
              <div class="text-[10px] uppercase tracking-wider text-slate-500">Cumulative return</div>
              <div class={`text-base font-semibold mt-1 ${state.cumulativeReturnPct >= 0 ? 'text-emerald-700' : 'text-red-700'}`}>
                {fmtPct(state.cumulativeReturnPct)}
              </div>
            </div>
          </div>

          <div class="rounded-lg border border-slate-200 bg-white p-4">
            <div class="flex items-baseline justify-between gap-2 mb-2">
              <h2 class="text-sm font-semibold text-slate-900">Open positions</h2>
              <span class="text-xs text-slate-500">{state.openPositions.length} open</span>
            </div>
            {state.openPositions.length === 0 ? (
              <div class="text-xs text-slate-500 italic">No open paper positions.</div>
            ) : (
              <div class="overflow-x-auto">
                <table class="w-full text-xs">
                  <thead>
                    <tr class="text-left text-slate-500 border-b border-slate-200">
                      <th class="py-1.5 pr-3">Symbol</th>
                      <th class="py-1.5 pr-3">Qty</th>
                      <th class="py-1.5 pr-3">Avg entry</th>
                      <th class="py-1.5 pr-3">Position value</th>
                      <th class="py-1.5 pr-3">Stop</th>
                      <th class="py-1.5 pr-3">T1 / T2 / T3</th>
                      <th class="py-1.5 pr-3">Unrealized</th>
                      <th class="py-1.5 pr-3">Risk %</th>
                      <th class="py-1.5 pr-3">Opened</th>
                    </tr>
                  </thead>
                  <tbody>
                    {state.openPositions.map((p) => (
                      <tr class="border-b border-slate-100">
                        <td class="py-1.5 pr-3 font-semibold text-slate-900">{p.symbol}</td>
                        <td class="py-1.5 pr-3">{fmtQty(p.quantity)}</td>
                        <td class="py-1.5 pr-3">{fmtUsd(p.avgEntryPrice)}</td>
                        <td class="py-1.5 pr-3">{fmtUsd(p.positionValue)}</td>
                        <td class="py-1.5 pr-3">{p.stopLoss ? fmtUsd(p.stopLoss) : '—'}</td>
                        <td class="py-1.5 pr-3">
                          {p.takeProfit1 ? fmtUsd(p.takeProfit1) : '—'} /
                          {p.takeProfit2 ? fmtUsd(p.takeProfit2) : '—'} /
                          {p.takeProfit3 ? fmtUsd(p.takeProfit3) : '—'}
                        </td>
                        <td class={`py-1.5 pr-3 ${p.unrealizedPnl >= 0 ? 'text-emerald-700' : 'text-red-700'}`}>
                          {fmtUsd(p.unrealizedPnl)} ({fmtPct(p.unrealizedPnlPct)})
                        </td>
                        <td class="py-1.5 pr-3">{fmtPct(p.riskPctBankroll)}</td>
                        <td class="py-1.5 pr-3">{fmtTime(p.openedAt)}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
          </div>

          <div class="rounded-lg border border-slate-200 bg-white p-4">
            <div class="flex items-baseline justify-between gap-2 mb-2">
              <h2 class="text-sm font-semibold text-slate-900">Trade ledger (last 50)</h2>
              <span class="text-xs text-slate-500">{state.trades.length} total · unrealized {fmtUsd(state.unrealizedPnl)}</span>
            </div>
            {recentTrades.length === 0 ? (
              <div class="text-xs text-slate-500 italic">No paper trades simulated yet.</div>
            ) : (
              <div class="overflow-x-auto">
                <table class="w-full text-xs">
                  <thead>
                    <tr class="text-left text-slate-500 border-b border-slate-200">
                      <th class="py-1.5 pr-3">Time</th>
                      <th class="py-1.5 pr-3">Action</th>
                      <th class="py-1.5 pr-3">Symbol</th>
                      <th class="py-1.5 pr-3">Qty</th>
                      <th class="py-1.5 pr-3">Price</th>
                      <th class="py-1.5 pr-3">Notional</th>
                      <th class="py-1.5 pr-3">Fee</th>
                      <th class="py-1.5 pr-3">Slippage</th>
                      <th class="py-1.5 pr-3">Realized</th>
                      <th class="py-1.5 pr-3">Cash after</th>
                      <th class="py-1.5 pr-3">Source</th>
                    </tr>
                  </thead>
                  <tbody>
                    {recentTrades.map((t) => (
                      <tr class="border-b border-slate-100">
                        <td class="py-1.5 pr-3 text-slate-500">{fmtTime(t.createdAt)}</td>
                        <td class="py-1.5 pr-3 font-semibold text-slate-900">{t.action}</td>
                        <td class="py-1.5 pr-3">{t.symbol}</td>
                        <td class="py-1.5 pr-3">{fmtQty(t.quantity)}</td>
                        <td class="py-1.5 pr-3">{fmtUsd(t.price)}</td>
                        <td class="py-1.5 pr-3">{fmtUsd(t.notionalValue)}</td>
                        <td class="py-1.5 pr-3">{fmtUsd(t.fee)}</td>
                        <td class="py-1.5 pr-3">{fmtUsd(t.slippage)}</td>
                        <td class={`py-1.5 pr-3 ${t.realizedPnl >= 0 ? 'text-emerald-700' : 'text-red-700'}`}>
                          {fmtUsd(t.realizedPnl)}
                        </td>
                        <td class="py-1.5 pr-3">{fmtUsd(t.bankrollAfter)}</td>
                        <td class="py-1.5 pr-3 text-slate-500">{t.source}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
          </div>

          <div class="rounded-lg border border-slate-200 bg-white p-4">
            <h2 class="text-sm font-semibold text-slate-900 mb-2">Risk settings</h2>
            <div class="grid gap-2 md:grid-cols-3 lg:grid-cols-6 text-xs">
              <div><span class="text-slate-500">Max risk / trade</span><div class="font-semibold">{fmtPct(state.riskSettings.maxRiskPerTradePct)}</div></div>
              <div><span class="text-slate-500">Max single position</span><div class="font-semibold">{fmtPct(state.riskSettings.maxSinglePositionPct)}</div></div>
              <div><span class="text-slate-500">Max total exposure</span><div class="font-semibold">{fmtPct(state.riskSettings.maxTotalExposurePct)}</div></div>
              <div><span class="text-slate-500">Min cash</span><div class="font-semibold">{fmtPct(state.riskSettings.minCashPct)}</div></div>
              <div><span class="text-slate-500">Fee</span><div class="font-semibold">{fmtPct(state.riskSettings.feePct)}</div></div>
              <div><span class="text-slate-500">Slippage</span><div class="font-semibold">{fmtPct(state.riskSettings.slippagePct)}</div></div>
            </div>
            <p class="text-[11px] text-slate-500 mt-3">
              Mode: <code>paper</code>. State key <code>crypto-paper-portfolio:state</code>.
              State updated {fmtTime(state.updatedAt)}.
            </p>
          </div>
        </>
      )}

      <SystemNav client:load activeHref="/admin/system/crypto-paper-portfolio" />
    </div>
  </div>
</BaseLayout>
