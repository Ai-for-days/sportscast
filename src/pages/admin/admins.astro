---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import AdminAccountsCenter from '../../components/admin/AdminAccountsCenter';
import { requireAdmin } from '../../lib/admin-auth';
export const prerender = false;
const session = await requireAdmin(Astro.request);
if (!session) { return Astro.redirect('/admin'); }
// Owner-only enforcement happens in the API (manage_users_and_roles); the
// component shows an "owner only" notice for non-owners.
---
<BaseLayout title="Manage Admins — Admin" noTitleSuffix noIndex>
  <div class="min-h-screen bg-white" style="color-scheme: light;">
    <div class="mx-auto max-w-7xl px-4 py-6">
      <AdminAccountsCenter client:only="react" />
    </div>
  </div>
</BaseLayout>
