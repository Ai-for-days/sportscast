---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import AdminSearch from '../../components/admin/AdminSearch';
import { requireAdmin } from '../../lib/admin-auth';
export const prerender = false;
const session = await requireAdmin(Astro.request);
if (!session) { return Astro.redirect('/admin'); }
---
<BaseLayout title="Search Admin Tools — Admin" noTitleSuffix noIndex>
  <div class="min-h-screen bg-white" style="color-scheme: light;">
    <div class="mx-auto max-w-5xl px-4 py-6">
      <AdminSearch client:only="react" />
    </div>
  </div>
</BaseLayout>
