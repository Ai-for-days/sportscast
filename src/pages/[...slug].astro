---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Breadcrumbs from '../components/layout/Breadcrumbs.astro';
import WeatherHero from '../components/forecast/WeatherHero';
import WeatherAlerts from '../components/forecast/WeatherAlerts';
import ForecastWagers from '../components/wagers/ForecastWagers';
import TodaysWeather from '../components/forecast/TodaysWeather';
import HourlyForecast from '../components/forecast/HourlyForecast';
import DailyForecast from '../components/forecast/DailyForecast';
import SportsMetrics from '../components/forecast/SportsMetrics';
import FishingForecast from '../components/forecast/FishingForecast';
import HuntingForecast from '../components/forecast/HuntingForecast';
import TemperatureChart from '../components/forecast/TemperatureChart';
import PrecipChart from '../components/forecast/PrecipChart';
import WindChart from '../components/forecast/WindChart';
import ForecastMaps from '../components/forecast/ForecastMaps';
import ForecastIntelligenceCard from '../components/forecast/ForecastIntelligenceCard';
import ForecastRevisionSummary from '../components/forecast/ForecastRevisionSummary';
import ForecastTimeline from '../components/forecast/ForecastTimeline';
import WeatherMarketContextCard from '../components/forecast/WeatherMarketContextCard';
import { buildForecastIntelligence } from '../lib/forecast-intelligence';
import { captureRevision, listSnapshots, locationKey } from '../lib/forecast-revision-store';
import { buildRevisionSummary, type ForecastRevisionSummary as ForecastRevisionSummaryShape } from '../lib/forecast-revision-analysis';
import { buildForecastTimeline, type ForecastTimelineResult } from '../lib/forecast-timeline';
import { buildWeatherMarketContext } from '../lib/weather-market-context';
import AllergyOutlook from '../components/forecast/AllergyOutlook';
import LocalContent from '../components/forecast/LocalContent.astro';
import WeatherOverview from '../components/forecast/WeatherOverview.astro';
import {
  UVIndexCard,
  SunriseSunsetCard,
  VisibilityCard,
  HumidityDewPointCard,
  PressureCard,
  AirQualityCard,
  CloudCoverCard,
  CloudCeilingCard,
} from '../components/forecast/WeatherDetailCards';
import { getForecast } from '../lib/weather-queries';
import { parseLocationSlug, geocodePostalCode } from '../lib/slug-utils';
import { stateAbbrToSlug } from '../lib/state-names';
import { getVenuesByCity } from '../lib/venue-data';
import { getTimeOfDay, getSkyGradient, isLightBackground } from '../lib/sky-theme';
import { getPriorityZipContent } from '../lib/priority-zip-content';
// Step 174 — scalable ZIP SEO template + internal-link module.
import { buildZipSeo } from '../lib/seo/zip-seo';
import { getRelatedZipsForZip } from '../lib/seo/zip-priority';
import ForecastInternalLinks from '../components/seo/ForecastInternalLinks.astro';
import {
  getBreadcrumbSchema,
  getPlaceSchema,
  getSpecialAnnouncementSchema,
  getFAQSchema,
  getWebPageSchema,
} from '../lib/schema-markup';
import zipData from '../data/us-zip-codes.json';

export const prerender = false;

const { slug } = Astro.params;
const slugStr = Array.isArray(slug) ? slug.join('/') : (slug || '');

// Resolve the slug to a geo record. Two supported shapes:
//   1. A SEO postal-code slug ("south-carolina-columbia-29209") — parsed
//      and forward-geocoded to lat/lon.
//   2. A "use my location" fallback ("forecast/<lat>,<lon>") — when reverse
//      geocoding could not pin down a postal code. We render the page
//      directly from the lat/lon plus whatever city/state Nominatim was
//      able to return, so the user is never silently bounced back to /.
type GeoRecord = {
  lat: number;
  lon: number;
  city: string;
  state: string;
  zip: string;
  countryCode: string;
};

let geo: GeoRecord | null = null;

const parsed = parseLocationSlug(slugStr);
if (parsed) {
  geo = await geocodePostalCode(parsed.postalCode, parsed.countryCode);
} else {
  const coordMatch = slugStr.match(/^forecast\/([-\d.]+),([-\d.]+)$/);
  if (coordMatch) {
    const rLat = parseFloat(coordMatch[1]);
    const rLon = parseFloat(coordMatch[2]);
    if (Number.isFinite(rLat) && Number.isFinite(rLon)) {
      // Try to upgrade to the canonical zip URL; if no zip is available,
      // synthesize a geo record from whatever city/state we got back and
      // render the page directly. Avoids a redirect loop when reverse-
      // geocode can only return /forecast/<lat>,<lon>.
      let revCity = '';
      let revState = '';
      let revZip = '';
      let revCountry = 'us';
      try {
        const revRes = await fetch(`${Astro.url.origin}/api/reverse-geocode?lat=${rLat}&lon=${rLon}`);
        if (revRes.ok) {
          const revData = await revRes.json();
          if (revData.url && !revData.url.startsWith('/forecast/')) {
            return Astro.redirect(revData.url);
          }
          revCity = typeof revData.city === 'string' ? revData.city : '';
          revState = typeof revData.state === 'string' ? revData.state : '';
          revZip = typeof revData.zip === 'string' ? revData.zip : '';
          revCountry = typeof revData.countryCode === 'string' && revData.countryCode
            ? revData.countryCode
            : 'us';
        }
      } catch {}
      geo = {
        lat: rLat,
        lon: rLon,
        city: revCity,
        state: revState,
        zip: revZip,
        countryCode: revCountry,
      };
    }
  }
}

if (!geo) {
  return Astro.redirect('/');
}

const { lat, lon } = geo;
const forecast = await getForecast(lat, lon, 15);
// Coord-fallback URLs may have empty city/state when reverse-geocode came
// up dry. Use a friendly placeholder so labels never render as ", " or
// stray-comma fragments.
const hasCity = !!geo.city;
const hasState = !!geo.state;
const coordLabel = `${lat.toFixed(2)}°, ${lon.toFixed(2)}°`;
const locationName =
  hasCity && hasState
    ? `${geo.city}, ${geo.state}`
    : geo.city || geo.state || `Your location (${coordLabel})`;
const locationLabel =
  hasCity && hasState
    ? `${geo.city}, ${geo.state}${geo.zip ? ` ${geo.zip}` : ''}`
    : locationName;
const today = forecast.daily[0];
const tomorrow = forecast.daily[1];
const _timeOfDay = getTimeOfDay(forecast.current.time, today.sunrise, today.sunset);
const skyGradient = getSkyGradient(forecast.current.description, forecast.current.cloudCover, _timeOfDay);
const skyIsLight = isLightBackground(forecast.current.description, _timeOfDay);

// Check if this city hosts any outdoor venues
const cityVenues = getVenuesByCity(geo.city, geo.state).filter(v => v.type === 'outdoor');
const venueList = cityVenues.map(v => ({
  name: v.name,
  team: v.team || '',
  sport: v.sport === 'multi' ? '' : v.sport,
}));

// Step 175 — title + description derive from the scalable
// `buildZipSeo` bundle so every ZIP gets the richer template (priority
// ZIPs short-circuit to their custom title inside the bundle).
// `getLocationMeta` is no longer used here; it remains in
// `lib/seo-meta.ts` for any future callers.

// Step 173 Part B — priority ZIPs get a focused title + H1 + unique
// intro from `priority-zip-content.ts`.
// Step 174 — non-priority ZIPs now flow through the scalable
// `buildZipSeo` template so they get a consistent title format + a
// varied intro paragraph instead of the legacy generic description.
// Step 175 — bundle also carries a second body paragraph + curated
// related ZIPs sourced from the city's other ZIP codes, so every
// non-priority ZIP page reads more like a real city page.
const priorityZip = getPriorityZipContent(geo.zip);
interface ZipDataEntry { z: string; c: string; s: string; lat: number; lon: number; }
const allZips = zipData as ZipDataEntry[];
// Step 176 — nearby/related selection uses the shared tier helper so
// Tier-1 ZIPs in the same city (and Tier-1 fallbacks across the same
// state) come first. Falls back gracefully if `geo.city`/`geo.state`
// is empty (coordinate-fallback path).
const nearbyZips: Array<{ zip: string; city: string; state: string }> =
  geo.city && geo.state
    ? getRelatedZipsForZip(
        allZips,
        { z: geo.zip, c: geo.city, s: geo.state },
        8,
      ).map((z) => ({ zip: z.z, city: z.c, state: z.s }))
    : [];
const zipSeo = buildZipSeo({
  city: geo.city,
  state: geo.state,
  zip: geo.zip,
  tempF: forecast.current.tempF,
  highF: today.highF,
  lowF: today.lowF,
  precipChance: today.precipProbability,
  description: forecast.current.description,
  alerts: forecast.alerts,
  nearbyZips,
});
// Step 175 — title comes from zipSeo (or priorityZip.title), description
// always from zipSeo so OG/Twitter pick up the richer scalable copy.
const seoMeta = {
  title: priorityZip ? priorityZip.title : zipSeo.title,
  description: zipSeo.description,
  noTitleSuffix: true,
};

// Step 129: derive lightweight forecast confidence/volatility/trend
// metadata server-side so the card hydrates with stable text. Pure
// heuristic — no external calls, no model APIs, no scientific overclaim.
const forecastIntelligence = buildForecastIntelligence(forecast);

// Step 130: persist a compact snapshot for this location and compare
// against the most recent prior snapshot. Defensive: if Redis is
// unreachable in this environment we silently fall back to "no
// revision data" rather than failing the page render.
const locKey = locationKey({
  zip: geo.zip,
  countryCode: geo.countryCode,
  lat,
  lon,
});
let revisionSummary: ForecastRevisionSummaryShape = {
  priorCapturedAt: null,
  comparedLabel: null,
  generatedAtUnchanged: false,
  isInitial: true,
  isUnchanged: false,
  changes: [],
  headline: null,
};
let forecastTimeline: ForecastTimelineResult = { entries: [], narrativeSummary: null };
try {
  const { prior, current } = await captureRevision(forecast, locKey, forecastIntelligence);
  revisionSummary = buildRevisionSummary(prior, current);

  // Step 131: pull a bounded chain of recent snapshots (newest first) and
  // render older revisions as a chronological timeline. The most-recent
  // pair is skipped because the Step 130 ForecastRevisionSummary card
  // already covers that delta.
  const recent = await listSnapshots(locKey, 12);
  forecastTimeline = buildForecastTimeline(recent, { skipMostRecentPair: true });
} catch (err) {
  console.warn('[step-130/131] forecast revision capture failed:', err);
}

// Step 132: derive a neutral, non-advisory market context summary from
// the Step 129/130/131 outputs. Pure heuristic, no betting advice. The
// component renders nothing when isEmpty so the page stays breathable.
const weatherMarketContext = buildWeatherMarketContext({
  intelligence: forecastIntelligence,
  revision: revisionSummary,
  timeline: forecastTimeline,
});

// Schema markup
const pageUrl = Astro.url.pathname;
const stateSlug = stateAbbrToSlug(geo.state.length <= 3 ? geo.state : geo.state.toLowerCase().replace(/\s+/g, '-'));
const breadcrumbItems = [
  { name: 'Home', url: '/' },
  ...(hasState ? [{ name: `${geo.state} Weather`, url: `/weather/${stateSlug}` }] : []),
  { name: `${locationName} Weather`, url: pageUrl },
];
const schemas: object[] = [
  getBreadcrumbSchema(breadcrumbItems),
  // Step 175 — WebPage schema so each ZIP page is explicitly an
  // entity on the site, not just a Place + FAQ pair.
  getWebPageSchema({
    name: zipSeo.h1,
    description: zipSeo.description,
    url: pageUrl,
  }),
  getPlaceSchema({
    city: geo.city,
    state: geo.state,
    zip: geo.zip,
    lat,
    lon,
    tempF: forecast.current.tempF,
    description: forecast.current.description,
    humidity: forecast.current.humidity,
    windSpeedMph: forecast.current.windSpeedMph,
    url: pageUrl,
  }),
  getFAQSchema({
    city: geo.city,
    state: geo.state,
    tempF: forecast.current.tempF,
    description: forecast.current.description,
    precipChance: today.precipProbability,
    highF: today.highF,
    lowF: today.lowF,
    humidity: forecast.current.humidity,
    windSpeedMph: forecast.current.windSpeedMph,
    feelsLikeF: forecast.current.feelsLikeF,
    uvIndex: forecast.current.uvIndex,
    sunrise: today.sunrise,
    sunset: today.sunset,
  }),
];

// Add SpecialAnnouncement for active alerts
if (forecast.alerts && forecast.alerts.length > 0) {
  const alert = forecast.alerts[0];
  schemas.push(getSpecialAnnouncementSchema({
    event: alert.event,
    headline: alert.headline || alert.event,
    description: alert.description || '',
    onset: alert.onset,
    expires: alert.expires,
    city: geo.city,
    state: geo.state,
    url: pageUrl,
  }));
}
---

<BaseLayout
  title={seoMeta.title}
  description={seoMeta.description}
  jsonLd={schemas}
>
  <div class="mx-auto max-w-4xl overflow-x-hidden px-4 py-6">
    <div class="mb-4">
      <Breadcrumbs items={[
        { label: 'Home', href: '/' },
        ...(hasState ? [{ label: `${geo.state} Weather`, href: `/weather/${stateSlug}` }] : []),
        { label: `${locationName} Weather` },
      ]} />
    </div>

    <!-- Visually hidden H1 keeps the page's primary heading near the
         top of the DOM for SEO without occupying screen space. The
         full SEO card (heading + intro + body) renders at the bottom
         of the page per operator request, since visitors want the
         forecast data first. -->
    <h1 class="sr-only">{priorityZip ? priorityZip.h1 : zipSeo.h1}</h1>

    <div class="space-y-4">
      <!-- Weather Hero -->
      <WeatherHero client:only="react" current={forecast.current} today={today} hourly={forecast.hourly} locationName={locationName} zip={geo.zip} venues={venueList} utcOffsetSeconds={forecast.utcOffsetSeconds} lat={lat} lon={lon} />

      <!-- Weather Alerts -->
      <WeatherAlerts client:only="react" alerts={forecast.alerts} />

      <!-- Forecast Outlook (Step 129: lightweight confidence/volatility/trend layer; Step 133: + source label) -->
      <ForecastIntelligenceCard
        client:only="react"
        summary={forecastIntelligence}
        sourceLabel={forecast.source?.label}
      />

      <!-- Forecast Changes (Step 130: revision tracking; renders nothing on first observation) -->
      <ForecastRevisionSummary client:only="react" summary={revisionSummary} />

      <!-- Forecast History (Step 131: chronological revision timeline; renders nothing until snapshots accumulate) -->
      <ForecastTimeline client:only="react" timeline={forecastTimeline} />

      <!-- Market Context (Step 132: neutral, non-advisory; renders nothing when isEmpty) -->
      <WeatherMarketContextCard client:only="react" context={weatherMarketContext} />

      <!-- Open wagers for this location -->
      <ForecastWagers client:only="react" cityName={locationName} />

      <!-- Today's Weather Summary -->
      <TodaysWeather client:only="react" today={today} current={forecast.current} hourly={forecast.hourly} />

      <!-- Weather Overview (SSR — featured snippet targeting) -->
      <WeatherOverview
        city={geo.city}
        state={geo.state}
        tempF={forecast.current.tempF}
        feelsLikeF={forecast.current.feelsLikeF}
        description={forecast.current.description}
        highF={today.highF}
        lowF={today.lowF}
        precipChance={today.precipProbability}
        humidity={forecast.current.humidity}
        windSpeedMph={forecast.current.windSpeedMph}
        uvIndex={forecast.current.uvIndex}
      />

      <!-- Hourly Strip -->
      <HourlyForecast client:only="react" hourly={forecast.hourly} current={forecast.current} locationName={locationLabel} />

      <!-- Temperature Trend -->
      <TemperatureChart client:only="react" hourly={forecast.hourly} locationName={locationLabel} />

      <!-- 15-Day Forecast -->
      <DailyForecast client:only="react" daily={forecast.daily} locationName={locationLabel} />

      <!-- Wind (compass + chart combined) -->
      <WindChart client:only="react" hourly={forecast.hourly} current={forecast.current} locationName={locationLabel} />

      <!-- Precipitation (summary + chart combined) -->
      <PrecipChart client:only="react" hourly={forecast.hourly} current={forecast.current} today={today} locationName={locationLabel} />

      <!-- Weather Maps -->
      <ForecastMaps client:only="react" lat={lat} lon={lon} daily={forecast.daily} hourly={forecast.hourly} stateCode={geo.state} zip={geo.zip} cityName={geo.city} />

      <!-- Sun & Moon + Weather Detail Cards (Step 128: stable surfaces — no more sky gradient stacking) -->
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 sm:gap-4">
        <SunriseSunsetCard client:only="react" today={today} tomorrow={tomorrow} lat={lat} lon={lon} utcOffsetSeconds={forecast.utcOffsetSeconds} />
        <UVIndexCard client:only="react" current={forecast.current} />
        <AirQualityCard client:only="react" airQuality={forecast.airQuality} lat={lat} lon={lon} />
        <HumidityDewPointCard client:only="react" current={forecast.current} hourly={forecast.hourly} />
      </div>

      <!-- More Weather Detail Cards -->
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 sm:gap-4">
        <CloudCeilingCard client:only="react" current={forecast.current} />
        <VisibilityCard client:only="react" current={forecast.current} />
        <PressureCard client:only="react" current={forecast.current} />
        <CloudCoverCard client:only="react" current={forecast.current} />
      </div>

      <!-- Allergy Outlook -->
      <AllergyOutlook client:only="react" allergyData={forecast.allergyData} locationName={locationLabel} />

      <!-- Local Content (SSR — no JS) -->
      <LocalContent
        city={geo.city}
        state={geo.state}
        zip={geo.zip}
        lat={lat}
        lon={lon}
        currentTempF={forecast.current.tempF}
        currentDescription={forecast.current.description}
        precipProbability={today.precipProbability}
        windSpeedMph={forecast.current.windSpeedMph}
      />

      <!-- Sports Playability -->
      <SportsMetrics client:only="react" hourly={forecast.hourly} lat={lat} lon={lon} cityName={geo.city} stateName={geo.state} />

      <!-- Fishing Forecast -->
      <FishingForecast client:only="react" forecast={forecast.current} tomorrowForecast={forecast.hourly.find(h => h.time.startsWith(tomorrow.date + 'T12')) || forecast.hourly.find(h => h.time.startsWith(tomorrow.date)) || forecast.current} lat={lat} lon={lon} utcOffsetSeconds={forecast.utcOffsetSeconds} today={today.date} tomorrowDate={tomorrow.date} state={geo.state} locationName={locationLabel} />

      <!-- Hunting Forecast -->
      <HuntingForecast client:only="react" forecast={forecast.current} tomorrowForecast={forecast.hourly.find(h => h.time.startsWith(tomorrow.date + 'T12')) || forecast.hourly.find(h => h.time.startsWith(tomorrow.date)) || forecast.current} lat={lat} lon={lon} utcOffsetSeconds={forecast.utcOffsetSeconds} today={today.date} tomorrowDate={tomorrow.date} state={geo.state} locationName={locationLabel} />

      <!-- Step 174 / 175 — internal-link module. Public links only; never admin. -->
      <ForecastInternalLinks
        parentCityHubUrl={zipSeo.parentCityHubUrl}
        parentStateHubUrl={zipSeo.parentStateHubUrl}
        parentCityName={geo.city}
        parentStateName={geo.state}
        featuredZipUrls={zipSeo.featuredZipUrls}
        relatedZipLinks={zipSeo.relatedZipLinks}
      />

      <!-- SEO content card (moved to bottom per operator preference).
           Visible heading renders here as <h2> since the page's
           primary <h1> is at the top of the document (sr-only). -->
      {priorityZip ? (
        <section class="rounded-xl border border-border bg-surface p-5 shadow-sm dark:border-border-dark dark:bg-surface-dark-alt">
          <h2 class="mb-2 text-xl font-bold text-text sm:text-2xl dark:text-text-dark">
            {priorityZip.h1}
          </h2>
          <p class="text-sm leading-relaxed text-text-muted dark:text-text-dark-muted">
            {priorityZip.intro}
          </p>
        </section>
      ) : (
        <section class="rounded-xl border border-border bg-surface p-5 shadow-sm dark:border-border-dark dark:bg-surface-dark-alt">
          <h2 class="mb-2 text-xl font-bold text-text sm:text-2xl dark:text-text-dark">
            {zipSeo.h1}
          </h2>
          <p class="text-sm leading-relaxed text-text-muted dark:text-text-dark-muted">
            {zipSeo.intro}
          </p>
          {zipSeo.body && (
            <p class="mt-3 text-sm leading-relaxed text-text-muted dark:text-text-dark-muted">
              {zipSeo.body}
            </p>
          )}
        </section>
      )}
    </div>
  </div>
</BaseLayout>
