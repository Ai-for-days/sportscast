---
// ── Step 173 Part B: City weather hub ────────────────────────────────────
//
// `/weather/{state-slug}/{city-slug}` — links up to the state hub and
// down to top ZIP codes in the city. Self-canonical non-www. Indexable
// (no `noIndex`). Public surface only — no admin data, no draft state.

import BaseLayout from '../../../components/layout/BaseLayout.astro';
import Breadcrumbs from '../../../components/layout/Breadcrumbs.astro';
import { STATE_ABBR_TO_FULL, stateAbbrToSlug } from '../../../lib/state-names';
import { cities } from '../../../lib/us-cities';
import { buildLocationSlug } from '../../../lib/slug-utils';
import { getBreadcrumbSchema, getCollectionPageSchema } from '../../../lib/schema-markup';
import { listPriorityZips } from '../../../lib/priority-zip-content';
import { getFeaturedZipsForCity } from '../../../lib/seo/zip-priority';
import zipData from '../../../data/us-zip-codes.json';

export const prerender = false;

const { state: stateSlug, city: citySlug } = Astro.params;
if (!stateSlug || !citySlug) return Astro.redirect('/');

// Resolve state slug → abbreviation
const SLUG_TO_ABBR: Record<string, string> = {};
for (const [abbr, slug] of Object.entries(STATE_ABBR_TO_FULL)) {
  SLUG_TO_ABBR[slug] = abbr;
}
const stateAbbr = SLUG_TO_ABBR[stateSlug];
if (!stateAbbr) return Astro.redirect('/');

const stateName = stateSlug
  .split('-')
  .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
  .join(' ');

// Find the city in the curated us-cities list.
const cityRecord = cities.find(
  (c) => c.state === stateAbbr && c.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '') === citySlug,
);
if (!cityRecord) return Astro.redirect(`/weather/${stateSlug}`);

const cityName = cityRecord.name;

// Pull all ZIP codes in the city.
interface ZipEntry {
  z: string;
  c: string;
  s: string;
  lat: number;
  lon: number;
}
const allZips = zipData as ZipEntry[];
const cityZips = allZips.filter(
  (z) => z.s === stateAbbr && z.c.toLowerCase() === cityName.toLowerCase(),
);
cityZips.sort((a, b) => a.z.localeCompare(b.z));

// Step 176 — curated ZIP list driven by the shared tier helper so
// Tier-1 ZIPs (including Step 173 priority designations) bubble
// to the top across every city hub.
const priorityZipSet = new Set(listPriorityZips().map((p) => p.zip));
const topZips = getFeaturedZipsForCity(cityZips, stateAbbr, cityName, 20);

const title = `${cityName}, ${stateAbbr} Weather Forecast: ZIP Codes, Hourly, 10-Day & 15-Day`;
const description =
  `${cityName}, ${stateAbbr} weather forecast hub. Browse current conditions, hourly changes, and ` +
  `10-day to 15-day outlooks for ${cityZips.length} ZIP codes across ${cityName}.`;

// Step 175 — related city links: surface up to 6 other major cities in
// the same state so each city hub crawls sideways into siblings. Safe
// fact: we only list cities that exist in the curated `us-cities.ts`
// dataset; no fabricated neighborhood claims.
const relatedCityLinks = cities
  .filter(c => c.state === stateAbbr && c.name !== cityName)
  .sort((a, b) => a.tier - b.tier || a.name.localeCompare(b.name))
  .slice(0, 6)
  .map(c => ({
    name: c.name,
    url: `/weather/${stateAbbrToSlug(stateAbbr)}/${c.name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}`,
  }));

// CollectionPage items reflect the curated `topZips` list — every URL
// is a real ZIP forecast page.
const collectionItems = topZips.map(z => ({
  name: `${cityName}, ${stateAbbr} ${z.z}`,
  url: buildLocationSlug(z.z, cityName, stateAbbr, 'us'),
}));

const schemas = [
  getBreadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: `${stateName} Weather`, url: `/weather/${stateSlug}` },
    { name: `${cityName} Weather`, url: `/weather/${stateSlug}/${citySlug}` },
  ]),
  // Step 174 / 175 — CollectionPage schema with curated ZIP items so
  // each city hub explicitly aggregates ZIP forecast pages.
  getCollectionPageSchema({
    name: `${cityName}, ${stateAbbr} Weather Forecasts`,
    url: `/weather/${stateSlug}/${citySlug}`,
    description: `Weather forecasts for ${cityZips.length} ZIP codes across ${cityName}, ${stateAbbr}.`,
    items: collectionItems,
    numberOfItems: cityZips.length,
  }),
];

Astro.response.headers.set('Cache-Control', 'public, s-maxage=900, stale-while-revalidate=1800');
---

<BaseLayout title={title} description={description} jsonLd={schemas} noTitleSuffix>
  <div class="mx-auto max-w-4xl px-4 py-6">
    <div class="mb-4">
      <Breadcrumbs items={[
        { label: 'Home', href: '/' },
        { label: `${stateName} Weather`, href: `/weather/${stateSlug}` },
        { label: `${cityName} Weather` },
      ]} />
    </div>

    <h1 class="mb-2 text-2xl font-bold text-text sm:text-3xl dark:text-text-dark">
      {cityName}, {stateAbbr} Weather Forecast
    </h1>

    <p class="mb-6 text-sm leading-relaxed text-text-muted dark:text-text-dark-muted">
      Browse current weather, hourly conditions, and 10-day to 15-day outlooks for
      every ZIP code in {cityName}, {stateAbbr}. Local conditions can vary by
      neighborhood — downtown, suburbs, and outlying ZIPs often see different
      temperatures, precipitation, and wind.
    </p>

    <section class="rounded-xl border border-border bg-surface p-5 shadow-sm dark:border-border-dark dark:bg-surface-dark-alt">
      <h2 class="mb-3 text-lg font-semibold text-text dark:text-text-dark">
        {cityName} ZIP Codes ({cityZips.length})
      </h2>
      {topZips.length === 0 ? (
        <p class="text-sm text-text-muted dark:text-text-dark-muted">
          No ZIP codes found for {cityName}, {stateAbbr}.
        </p>
      ) : (
        <ul class="grid grid-cols-2 gap-2 sm:grid-cols-3">
          {topZips.map((z) => {
            const isPriority = priorityZipSet.has(z.z);
            const href = buildLocationSlug(z.z, cityName, stateAbbr, 'us');
            return (
              <li>
                <a
                  href={href}
                  class="block rounded-md border border-border/50 px-3 py-2 text-sm text-field hover:bg-surface-alt hover:text-field-dark dark:border-border-dark/50 dark:hover:bg-surface-dark"
                >
                  <span class="font-medium">{z.z}</span>
                  {isPriority && (
                    <span class="ml-2 inline-block rounded-full bg-amber-100 px-1.5 py-0.5 text-[10px] font-semibold text-amber-800">
                      featured
                    </span>
                  )}
                </a>
              </li>
            );
          })}
        </ul>
      )}
      {cityZips.length > topZips.length && (
        <p class="mt-3 text-xs text-text-muted dark:text-text-dark-muted">
          Showing top {topZips.length} of {cityZips.length} ZIP codes.
          <a href={`/weather/${stateSlug}`} class="ml-1 underline">
            See all {stateName} cities
          </a>.
        </p>
      )}
    </section>

    {relatedCityLinks.length > 0 && (
      <section class="mt-6 rounded-xl border border-border bg-surface p-5 shadow-sm dark:border-border-dark dark:bg-surface-dark-alt">
        <h2 class="mb-3 text-lg font-semibold text-text dark:text-text-dark">
          Other {stateName} cities
        </h2>
        <ul class="grid grid-cols-2 gap-2 sm:grid-cols-3 text-sm">
          {relatedCityLinks.map((rc) => (
            <li>
              <a href={rc.url} class="block rounded-md border border-border/50 px-3 py-2 text-field hover:bg-surface-alt dark:border-border-dark/50 dark:hover:bg-surface-dark">
                {rc.name} weather
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <p class="mt-4 text-sm text-text-muted dark:text-text-dark-muted">
      <a href={`/weather/${stateSlug}`} class="underline">
        ← Back to {stateName} weather
      </a>
      <span class="mx-2">·</span>
      <a href="/" class="underline">Wager on Weather homepage</a>
    </p>
  </div>
</BaseLayout>
