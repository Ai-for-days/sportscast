---
import HeaderSearch from '../search/HeaderSearch';

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Historical', href: '/historical' },
  { label: 'Venues', href: '/venues' },
];
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-border bg-surface/95 backdrop-blur-sm dark:border-border-dark dark:bg-surface-dark/95">
  <div class="mx-auto flex max-w-7xl items-center gap-3 px-4 py-3">
    <!-- Logo -->
    <a href="/" class="flex shrink-0 items-center gap-2 text-xl font-bold text-field-dark dark:text-field-light">
      <picture>
        <source srcset="/logo-header.webp" type="image/webp" />
        <img src="/logo-header.png" alt="Wager on Weather" class="h-10 w-auto" width="80" height="40" />
      </picture>
      <span class="hidden lg:inline">Wager on Weather</span>
    </a>

    <!-- City search. On mobile it now lives directly in the header bar
         (the hamburger menu has been removed); on desktop it's centered. -->
    <div class="flex min-w-0 flex-1 md:justify-center">
      <div class="w-full md:max-w-md">
        <HeaderSearch client:only="react" />
      </div>
    </div>

    <!-- Desktop nav (hidden on mobile — there is no hamburger fallback) -->
    <nav class="hidden shrink-0 items-center gap-2 md:flex">
      {navItems.map(item => (
        <a
          href={item.href}
          class:list={[
            'rounded-lg px-4 py-2 text-sm font-medium transition-colors whitespace-nowrap',
            currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
              ? 'bg-field/10 text-field-dark dark:text-field-light'
              : 'text-text-muted hover:bg-surface-alt hover:text-text dark:text-text-dark-muted dark:hover:bg-surface-dark-alt dark:hover:text-text-dark',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>
